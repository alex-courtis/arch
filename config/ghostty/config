config-file = ?appearance

# process
gtk-single-instance = false
linux-cgroup = always

# shell
shell-integration-features = no-title,no-cursor
app-notifications = no-clipboard-copy

# chrome
gtk-titlebar = false
scrollbar = never
window-padding-x = 0
window-padding-y = 0
window-padding-color = extend

# clipboard
clipboard-read = allow

# links
link-previews = false

# bell
bell-features = no-border,no-attention,no-title

# mouse
right-click-action = copy-or-paste

# map
keybind = clear

# map - new
keybind = super+shift+escape=new_window

keybind = ctrl+shift+r=reset
keybind = ctrl+shift+l=clear_screen

keybind = ctrl+shift+o=write_scrollback_file:open,plain
keybind = ctrl+alt+o=write_scrollback_file:copy,plain

keybind = ctrl+shift+s=write_screen_file:open,plain
keybind = ctrl+alt+s=write_screen_file:copy,plain

keybind = ctrl+==reset_font_size

keybind = ctrl+shift+enter=start_search

keybind = ctrl+shift+u=scroll_page_up
keybind = ctrl+shift+d=scroll_page_down
keybind = ctrl+shift+k=scroll_page_lines:-1
keybind = ctrl+shift+j=scroll_page_lines:1
keybind = ctrl+shift+g=scroll_to_top

# map - defaults
keybind = ctrl+shift+,=reload_config
# keybind = ctrl+,=open_config
keybind = copy=copy_to_clipboard:mixed
keybind = paste=paste_from_clipboard
# keybind = ctrl+insert=copy_to_clipboard:mixed
keybind = shift+insert=paste_from_selection
keybind = ctrl+shift+c=copy_to_clipboard:mixed
keybind = ctrl+shift+v=paste_from_clipboard
# keybind = ctrl+==increase_font_size:1
keybind = ctrl++=increase_font_size:1
keybind = ctrl+-=decrease_font_size:1
